; Engine configuration file.
; SLEEPOVER — Week 1 Kill Test (single-player locomotion prototype)
; Godot 4.3+  —  open this folder as a project in the Godot editor.

config_version=5

[application]

config/name="Sleepover"
config/description="Trapped. Hunted. Don't fall asleep."
run/main_scene="res://core/ui/AppRoot.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

; Global "noise ping" bus. Player emits pings; monster listens.
NoiseBus="*res://core/audio/NoiseBus.gd"
; Steam init + lobby helpers (GodotSteam). Fails soft into solo mode.
SteamManager="*res://core/networking/SteamManager.gd"
; Host-authoritative lobby roster/ready/start sync.
LobbyManager="*res://core/networking/LobbyManager.gd"

[navigation]

; Match the house navmesh bake (Main.gd) so map and mesh agree on voxel size.
3d/default_cell_size=0.2
3d/default_cell_height=0.2
; Stairwell NavigationLink3D endpoints must reach floor meshes ~1.5m away
; (the eroded mesh edges sit back from the stair holes).
3d/default_link_connection_radius=2.0

[physics]

; Slightly punchier gravity feels better for comedy hops.
3d/default_gravity=12.0

[rendering]

lights_and_shadows/directional_shadow/size=2048
