; Engine configuration file.
; SLEEPOVER — Week 1 Kill Test (single-player locomotion prototype)
; Godot 4.3+  —  open this folder as a project in the Godot editor.

config_version=5

[application]

config/name="Sleepover — Week 1 Kill Test"
config/description="Prove sleeping-bag locomotion is funny in its ugliest form."
run/main_scene="res://games/sleepover/Main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

; Global "noise ping" bus. Player emits pings; monster listens.
NoiseBus="*res://core/audio/NoiseBus.gd"
; Steam init + lobby helpers (GodotSteam). Fails soft into solo mode.
SteamManager="*res://core/networking/SteamManager.gd"

[physics]

; Slightly punchier gravity feels better for comedy hops.
3d/default_gravity=12.0

[rendering]

lights_and_shadows/directional_shadow/size=2048
